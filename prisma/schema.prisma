model CustomerIdentity {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  customerId    String       @map("customer_id") @db.Uuid
  identityType  IdentityType @map("identity_type")
  identityValue String       @map("identity_value") @db.VarChar(255)
  isPrimary     Boolean      @default(false) @map("is_primary")
  isVerified    Boolean      @default(false) @map("is_verified")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, identityType, identityValue])
  @@index([tenantId, customerId])
  @@index([identityType])
  @@map("customer_identities")
}

model CustomerAddress {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  addressType AddressType @map("address_type") @default(HOME)
  line1       String      @db.VarChar(255)
  line2       String?     @db.VarChar(255)
  city        String      @db.VarChar(100)
  state       String?     @db.VarChar(100)
  country     String      @db.VarChar(10) // ISO 3166-1 alpha-2
  postalCode  String?     @map("postal_code") @db.VarChar(20)
  isDefault   Boolean     @default(false) @map("is_default")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([addressType])
  @@map("customer_addresses")
}

model CustomerDevice {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  customerId  String         @map("customer_id") @db.Uuid
  deviceType  String         @map("device_type") @db.VarChar(50) // MOBILE, TABLET, DESKTOP
  deviceToken String         @map("device_token") @db.VarChar(500)
  platform    DevicePlatform
  lastSeenAt  DateTime?      @map("last_seen_at") @db.Timestamptz
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, deviceToken])
  @@index([tenantId, customerId])
  @@index([platform])
  @@map("customer_devices")
}

// ===========================================
// DOMAIN 20: CUSTOMER COMMUNICATION PREFERENCES (Phase 2A)
// ===========================================

model CustomerChannel {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  customerId   String      @map("customer_id") @db.Uuid
  channelType  ChannelType @map("channel_type")
  channelValue String      @map("channel_value") @db.VarChar(255)
  isVerified   Boolean     @default(false) @map("is_verified")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, channelType])
  @@index([tenantId, customerId])
  @@index([channelType])
  @@map("customer_channels")
}

model CustomerPreference {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @map("tenant_id") @db.Uuid
  customerId       String      @unique @map("customer_id") @db.Uuid

  emailEnabled     Boolean     @default(true) @map("email_enabled")
  smsEnabled       Boolean     @default(true) @map("sms_enabled")
  whatsappEnabled  Boolean     @default(true) @map("whatsapp_enabled")
  pushEnabled      Boolean     @default(true) @map("push_enabled")

  preferredChannel ChannelType? @map("preferred_channel")
  preferredLanguage String?    @map("preferred_language") @db.VarChar(10) // e.g., en, hi, ta

  quietHoursStart  String?     @map("quiet_hours_start") @db.VarChar(5) // HH:MM
  quietHoursEnd    String?     @map("quiet_hours_end") @db.VarChar(5) // HH:MM

  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("customer_preferences")
}

model CustomerConsent {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  customerId  String        @map("customer_id") @db.Uuid
  consentType ConsentType   @map("consent_type")
  status      ConsentStatus @default(PENDING)
  grantedAt   DateTime?     @map("granted_at") @db.Timestamptz
  revokedAt   DateTime?     @map("revoked_at") @db.Timestamptz
  source      String?       @db.VarChar(100) // WEB_FORM, API, IMPORT, MANUAL
  proof       String?       @db.Text // Reference to consent proof (URL, record)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, consentType])
  @@index([tenantId, customerId])
  @@index([consentType])
  @@index([status])
  @@map("customer_consents")
}

// ===========================================
// DOMAIN 21: PRODUCT CATALOG (Phase 2A)
// ===========================================

model ProductCategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @db.VarChar(255)
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Uuid
  level       Int      @default(0) // Hierarchy depth
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("product_categories")
}

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  categoryId  String?       @map("category_id") @db.Uuid
  name        String        @db.VarChar(255)
  sku         String?       @db.VarChar(100)
  description String?       @db.Text
  basePrice   Decimal       @map("base_price") @db.Decimal(12, 2)
  currency    String        @default("INR") @db.VarChar(3)
  imageUrl    String?       @map("image_url") @db.VarChar(500)
  tags        Json?         @default("[]") // Product tags array
  status      ProductStatus @default(ACTIVE)
  metadata    Json?         @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        ProductCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attributeValues ProductAttributeValue[]
  affinities      CustomerProductAffinity[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@index([status])
  @@index([tenantId, name])
  @@map("products")
}

model ProductAttribute {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(100) // color, size, material, brand
  dataType  String   @map("data_type") @db.VarChar(50) // STRING, NUMBER, BOOLEAN
  isFilterable Boolean @default(false) @map("is_filterable")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values ProductAttributeValue[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_attributes")
}

model ProductAttributeValue {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  attributeId String   @map("attribute_id") @db.Uuid
  value       String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, attributeId])
  @@index([tenantId, productId])
  @@index([attributeId])
  @@map("product_attribute_values")
}

model CustomerProductAffinity {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  affinityScore   Decimal  @map("affinity_score") @db.Decimal(5, 4) // 0-1
  purchaseCount   Int      @default(0) @map("purchase_count")
  lastPurchasedAt DateTime? @map("last_purchased_at") @db.Timestamptz
  computedAt      DateTime @map("computed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, productId])
  @@index([tenantId, customerId])
  @@index([tenantId, productId])
  @@index([affinityScore])
  @@map("customer_product_affinities")
}

// ===========================================
// DOMAIN 22: FEATURE STORE HARDENING (Phase 2A)
// ===========================================

model FeatureDefinition {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  featureName String        @map("feature_name") @db.VarChar(100)
  description String?       @db.Text
  dataType    FeatureDataType @map("data_type") @default(NUMERIC)
  owner       String?       @db.VarChar(100) // Team or system that owns this feature
  status      FeatureStatus @default(ACTIVE)
  metadata    Json?         @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions FeatureVersion[]
  computationRuns FeatureComputationRun[]

  @@unique([tenantId, featureName])
  @@index([tenantId])
  @@index([status])
  @@map("feature_definitions")
}

model FeatureVersion {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  featureDefinitionId   String   @map("feature_definition_id") @db.Uuid
  version               Int
  formula               String?  @db.Text // SQL or computation formula
  description           String?  @db.Text
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureDefinition FeatureDefinition @relation(fields: [featureDefinitionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureDefinitionId, version])
  @@index([tenantId, featureDefinitionId])
  @@map("feature_versions")
}

model FeatureComputationRun {
  id                  String            @id @default(uuid()) @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  featureDefinitionId String            @map("feature_definition_id") @db.Uuid
  version             Int
  status              ComputationStatus @default(PENDING)
  startedAt           DateTime?         @map("started_at") @db.Timestamptz
  completedAt         DateTime?         @map("completed_at") @db.Timestamptz
  recordsProcessed    Int?              @map("records_processed")
  errorMessage        String?           @map("error_message") @db.Text
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureDefinition FeatureDefinition @relation(fields: [featureDefinitionId], references: [id], onDelete: Cascade)

  @@index([tenantId, featureDefinitionId])
  @@index([status])
  @@map("feature_computation_runs")
}

// ===========================================
// DOMAIN 23: DECISION ENGINE FOUNDATION (Phase 2A)
// ===========================================

model DecisionTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  goalType    GoalType @map("goal_type")
  template    Json     // Template structure (audience criteria, channel options, etc.)
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([goalType])
  @@map("decision_templates")
}

model DecisionRule {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  decisionId  String   @map("decision_id") @db.Uuid
  ruleName    String   @map("rule_name") @db.VarChar(255)
  ruleType    String   @map("rule_type") @db.VarChar(50) // AUDIENCE, CHANNEL, OFFER, TIMING, EXCLUSION
  conditions  Json     // Rule conditions
  actions     Json     // Rule actions
  priority    Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([tenantId, decisionId])
  @@index([ruleType])
  @@map("decision_rules")
}

model DecisionExplanation {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  decisionId  String   @map("decision_id") @db.Uuid
  stepName    String   @map("step_name") @db.VarChar(100) // AUDIENCE_SELECTION, CHANNEL_CHOICE, OFFER_SELECTION, TIMING
  explanation String   @db.Text
  evidence    Json?    // Supporting data
  confidence  Decimal? @db.Decimal(5, 4)
  stepOrder   Int      @map("step_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([tenantId, decisionId])
  @@map("decision_explanations")
}

model DecisionExperiment {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  decisionIdA    String   @map("decision_id_a") @db.Uuid
  decisionIdB    String   @map("decision_id_b") @db.Uuid
  trafficSplit   Decimal  @default(0.5) @map("traffic_split") @db.Decimal(3, 2) // 0-1 fraction for variant A
  status         String   @default("DRAFT") @db.VarChar(20) // DRAFT, RUNNING, COMPLETED, STOPPED
  startedAt      DateTime? @map("started_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  winnerDecisionId String? @map("winner_decision_id") @db.Uuid
  results        Json?    // Experiment results summary
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("decision_experiments")
}

// ===========================================
// DOMAIN 24: OFFERS (Phase 2A)
// ===========================================

model OfferTemplate {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  name        String     @db.VarChar(255)
  description String?    @db.Text
  offerType   OfferType  @map("offer_type")
  template    Json       // Template structure (value ranges, conditions)
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offers Offer[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([offerType])
  @@map("offer_templates")
}

model Offer {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @map("tenant_id") @db.Uuid
  templateId     String?     @map("template_id") @db.Uuid
  name           String      @db.VarChar(255)
  description    String?     @db.Text
  offerType      OfferType   @map("offer_type")
  value          Decimal     @db.Decimal(12, 2) // Discount amount, percentage, points, etc.
  currency       String?     @db.VarChar(3)
  conditions     Json?       // Eligibility conditions
  maxRedemptions Int?        @map("max_redemptions")
  currentRedemptions Int     @default(0) @map("current_redemptions")
  status         OfferStatus @default(DRAFT)
  validFrom      DateTime?   @map("valid_from") @db.Timestamptz
  validUntil     DateTime?   @map("valid_until") @db.Timestamptz
  metadata       Json?       @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template    OfferTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  assignments OfferAssignment[]
  performances OfferPerformance[]
  versions    OfferVersion[]

  @@index([tenantId])
  @@index([offerType])
  @@index([status])
  @@index([validFrom, validUntil])
  @@map("offers")
}

model OfferAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  offerId     String    @map("offer_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  decisionId  String?   @map("decision_id") @db.Uuid
  campaignId  String?   @map("campaign_id") @db.Uuid
  assignedAt  DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  redeemedAt  DateTime? @map("redeemed_at") @db.Timestamptz
  status      String    @default("ASSIGNED") @db.VarChar(20) // ASSIGNED, REDEEMED, EXPIRED, CANCELLED
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offer    Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([tenantId, offerId])
  @@index([status])
  @@map("offer_assignments")
}

model OfferPerformance {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  offerId          String   @map("offer_id") @db.Uuid
  totalAssigned    Int      @default(0) @map("total_assigned")
  totalRedeemed    Int      @default(0) @map("total_redeemed")
  totalRevenue     Decimal? @map("total_revenue") @db.Decimal(12, 2)
  redemptionRate   Decimal? @map("redemption_rate") @db.Decimal(5, 4)
  avgOrderValue    Decimal? @map("avg_order_value") @db.Decimal(12, 2)
  roi              Decimal? @db.Decimal(8, 4)
  computedAt       DateTime @map("computed_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offer  Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, offerId])
  @@index([computedAt])
  @@map("offer_performances")
}

// ===========================================
// DOMAIN 25: WORKFLOW ENGINE (Phase 2A)
// ===========================================

model Workflow {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  name        String         @db.VarChar(255)
  description String?        @db.Text
  triggerType String         @map("trigger_type") @db.VarChar(50) // MANUAL, SCHEDULED, EVENT, API
  triggerConfig Json?        @map("trigger_config")
  status      WorkflowStatus @default(DRAFT)
  version     Int            @default(1)
  metadata    Json?          @default("{}")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps      WorkflowStep[]
  executions WorkflowExecution[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@map("workflows")
}

model WorkflowStep {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  workflowId  String           @map("workflow_id") @db.Uuid
  stepName    String           @map("step_name") @db.VarChar(255)
  stepType    WorkflowStepType @map("step_type")
  config      Json             // Step-specific configuration
  nextStepId  String?          @map("next_step_id") @db.Uuid
  onFailStepId String?         @map("on_fail_step_id") @db.Uuid
  stepOrder   Int              @map("step_order")
  timeoutMs   Int?             @map("timeout_ms")
  retryCount  Int              @default(0) @map("retry_count")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  executionSteps WorkflowExecutionStep[]

  @@index([tenantId, workflowId])
  @@index([stepType])
  @@map("workflow_steps")
}

model WorkflowExecution {
  id          String                  @id @default(uuid()) @db.Uuid
  tenantId    String                  @map("tenant_id") @db.Uuid
  workflowId  String                  @map("workflow_id") @db.Uuid
  status      WorkflowExecutionStatus @default(PENDING)
  triggeredBy String?                 @map("triggered_by") @db.Uuid
  input       Json?                   // Execution input data
  output      Json?                   // Execution output data
  startedAt   DateTime?               @map("started_at") @db.Timestamptz
  completedAt DateTime?               @map("completed_at") @db.Timestamptz
  errorMessage String?                @map("error_message") @db.Text
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps    WorkflowExecutionStep[]

  @@index([tenantId, workflowId])
  @@index([status])
  @@index([startedAt])
  @@map("workflow_executions")
}

model WorkflowExecutionStep {
  id            String                  @id @default(uuid()) @db.Uuid
  tenantId      String                  @map("tenant_id") @db.Uuid
  executionId   String                  @map("execution_id") @db.Uuid
  stepId        String                  @map("step_id") @db.Uuid
  status        WorkflowExecutionStatus @default(PENDING)
  input         Json?
  output        Json?
  startedAt     DateTime?               @map("started_at") @db.Timestamptz
  completedAt   DateTime?               @map("completed_at") @db.Timestamptz
  errorMessage  String?                 @map("error_message") @db.Text
  attemptNumber Int                     @default(1) @map("attempt_number")
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  step      WorkflowStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([tenantId, executionId])
  @@index([stepId])
  @@index([status])
  @@map("workflow_execution_steps")
}

// ===========================================
// DOMAIN 26: AI MEMORY (Phase 2A)
// ===========================================

model AgentMemory {
  id         String     @id @default(uuid()) @db.Uuid
  tenantId   String     @map("tenant_id") @db.Uuid
  agentType  AIAgentType @map("agent_type")
  memoryType MemoryType @map("memory_type")
  key        String     @db.VarChar(255)
  value      Json       // Memory content
  confidence Decimal?   @db.Decimal(5, 4)
  expiresAt  DateTime?  @map("expires_at") @db.Timestamptz
  accessCount Int       @default(0) @map("access_count")
  lastAccessedAt DateTime? @map("last_accessed_at") @db.Timestamptz
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, agentType, key])
  @@index([tenantId])
  @@index([agentType])
  @@index([memoryType])
  @@map("agent_memories")
}

model AgentObservation {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  agentType     AIAgentType @map("agent_type")
  observationType String   @map("observation_type") @db.VarChar(100) // TREND, ANOMALY, INSIGHT, PATTERN
  subject       String      @db.VarChar(255) // What was observed about
  observation   String      @db.Text // The observation itself
  evidence      Json?       // Supporting data
  confidence    Decimal?    @db.Decimal(5, 4)
  actionable    Boolean     @default(false)
  actedUpon     Boolean     @default(false) @map("acted_upon")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([agentType])
  @@index([observationType])
  @@index([actionable])
  @@map("agent_observations")
}

model AgentFeedback {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  agentType       AIAgentType       @map("agent_type")
  interactionId   String?           @map("interaction_id") @db.Uuid
  decisionId      String?           @map("decision_id") @db.Uuid
  sentiment       FeedbackSentiment
  rating          Int?              // 1-5 scale
  comment         String?           @db.Text
  feedbackBy      String?           @map("feedback_by") @db.Uuid
  feedbackContext Json?             @map("feedback_context")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([agentType])
  @@index([sentiment])
  @@index([interactionId])
  @@map("agent_feedbacks")
}

// ===========================================
// DOMAIN 27: ANALYTICS FOUNDATION (Phase 2A)
// ===========================================

model MetricDefinition {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  formula        String?  @db.Text // SQL or computation formula
  aggregation    String   @default("SUM") @db.VarChar(20) // SUM, AVG, COUNT, MIN, MAX, CUSTOM
  unit           String?  @db.VarChar(50) // %, INR, count, days
  category       String?  @db.VarChar(100) // REVENUE, ENGAGEMENT, RETENTION, CAMPAIGN, CUSTOMER
  isSystem       Boolean  @default(false) @map("is_system")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshots MetricSnapshot[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([category])
  @@map("metric_definitions")
}

model MetricSnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  metricDefinitionId String   @map("metric_definition_id") @db.Uuid
  value              Decimal  @db.Decimal(16, 4)
  previousValue      Decimal? @map("previous_value") @db.Decimal(16, 4)
  changePercent      Decimal? @map("change_percent") @db.Decimal(8, 4)
  dimensions         Json?    // Slice dimensions (segment, channel, campaign)
  periodStart        DateTime @map("period_start") @db.Timestamptz
  periodEnd          DateTime @map("period_end") @db.Timestamptz
  computedAt         DateTime @map("computed_at") @db.Timestamptz
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metricDefinition MetricDefinition @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)

  @@index([tenantId, metricDefinitionId])
  @@index([periodStart, periodEnd])
  @@index([computedAt])
  @@map("metric_snapshots")
}

model DashboardWidget {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  widgetType  String   @map("widget_type") @db.VarChar(50) // CHART, TABLE, KPI, MAP, FUNNEL
  config      Json     // Widget configuration (data source, visualization options)
  position    Json?    // Grid position { x, y, w, h }
  dashboardId String?  @map("dashboard_id") @db.VarChar(100) // Group widgets into dashboards
  isVisible   Boolean  @default(true) @map("is_visible")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dashboardId])
  @@index([widgetType])
  @@map("dashboard_widgets")
}

// ===========================================
// DOMAIN 28: PRODUCT INTELLIGENCE (Phase 3.5)
// ===========================================

model CustomerCategoryAffinity {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  category        String   @db.VarChar(100)
  affinityScore   Decimal  @map("affinity_score") @db.Decimal(5, 4) // 0-1
  totalSpend      Decimal  @map("total_spend") @db.Decimal(12, 2)
  purchaseCount   Int      @default(0) @map("purchase_count")
  avgItemValue    Decimal? @map("avg_item_value") @db.Decimal(12, 2)
  lastPurchasedAt DateTime? @map("last_purchased_at") @db.Timestamptz
  isPreferred     Boolean  @default(false) @map("is_preferred")
  computedAt      DateTime @map("computed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, category])
  @@index([tenantId, customerId])
  @@index([affinityScore])
  @@index([category])
  @@map("customer_category_affinities")
}

// ===========================================
// DOMAIN 29: OFFER VERSIONING (Phase 3.5)
// ===========================================

model OfferVersion {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  offerId       String    @map("offer_id") @db.Uuid
  version       Int       @default(1)
  offerType     OfferType @map("offer_type")
  value         Decimal   @db.Decimal(12, 2)
  conditions    Json?
  changelog     String?   @db.Text
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offer  Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, offerId, version])
  @@index([tenantId, offerId])
  @@map("offer_versions")
}

// ===========================================
// DOMAIN 30: AI CHAT PERSISTENCE
// ===========================================

model Conversation {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @map("tenant_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  title     String        @db.VarChar(255)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([tenantId])
  @@index([userId])
  @@map("conversations")
}

model ChatMessage {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  role           String       @db.VarChar(50) // 'user' | 'assistant'
  content        String       @db.Text
  steps          Json?        // Stores intermediate tool steps: AgentStep[]
  timestamp      DateTime     @default(now()) @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}
