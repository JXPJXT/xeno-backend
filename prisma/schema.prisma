// ===========================================
// XENO AI DECISIONING PLATFORM
// Prisma Schema — Complete Database Design
// ===========================================
// 
// Philosophy: Identity → Behavior → Intelligence → Decision → Execution → Outcome → Learning
// Multi-tenancy: Shared schema with tenant_id discriminator
// Immutability: Events and audit logs are append-only
// Versioning: Critical entities preserve history
// Soft Delete: Business entities use deleted_at

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// ENUMS
// ===========================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  MANAGER
  MARKETER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum CustomerGender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum ActorType {
  SYSTEM
  USER
  API
}

enum PersonaAssignedBy {
  SYSTEM
  MANUAL
  AI
}

enum PersonaStatus {
  ACTIVE
  INACTIVE
}

enum SegmentType {
  STATIC
  DYNAMIC
  AI_GENERATED
}

enum SegmentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum GoalType {
  REACTIVATION
  RETENTION
  ACQUISITION
  UPSELL
  CROSS_SELL
  ENGAGEMENT
  WIN_BACK
  LOYALTY
  CUSTOM
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum DecisionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  APPROVED
  REJECTED
}

enum CampaignType {
  ONE_TIME
  RECURRING
  TRIGGERED
  AI_GENERATED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ChannelType {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  MULTI_CHANNEL
}

enum CampaignAudienceStatus {
  INCLUDED
  EXCLUDED
  SENT
  SKIPPED
}

enum CommunicationStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
  BOUNCED
}

enum DeliveryEventType {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
}

enum AttributionModel {
  FIRST_TOUCH
  LAST_TOUCH
  LINEAR
  TIME_DECAY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  LAUNCH
  PAUSE
  CANCEL
}

enum AIAgentType {
  INTENT
  CONTENT
  INSIGHTS
  DECISION
}

enum AIInteractionStatus {
  SUCCESS
  ERROR
  TIMEOUT
}

enum ChannelProviderStatus {
  ACTIVE
  INACTIVE
  DEGRADED
}

// ===========================================
// PHASE 2A ENUMS
// ===========================================

// Customer Identity
enum IdentityType {
  EMAIL
  PHONE
  LOYALTY_ID
  EXTERNAL_CRM_ID
  WHATSAPP_ID
}

enum AddressType {
  BILLING
  SHIPPING
  HOME
  WORK
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
  DESKTOP
}

// Communication Preferences
enum ConsentType {
  EMAIL_MARKETING
  SMS_MARKETING
  WHATSAPP_MARKETING
  PUSH_MARKETING
  ANALYTICS
  PERSONALIZATION
}

enum ConsentStatus {
  GRANTED
  REVOKED
  PENDING
}

// Product Catalog
enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
  OUT_OF_STOCK
}

// Feature Store
enum FeatureDataType {
  NUMERIC
  CATEGORICAL
  BOOLEAN
  ARRAY
  JSON
}

enum FeatureStatus {
  ACTIVE
  DEPRECATED
  EXPERIMENTAL
}

enum ComputationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// Offers
enum OfferType {
  PERCENTAGE_DISCOUNT
  FLAT_DISCOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
  CASHBACK
  LOYALTY_POINTS
  BUNDLE
  CUSTOM
}

enum OfferStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

// Workflows
enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowStepType {
  ACTION
  CONDITION
  DELAY
  SPLIT
  WEBHOOK
  APPROVAL
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

// AI Memory
enum MemoryType {
  FACT
  PREFERENCE
  STRATEGY
  INSIGHT
  PATTERN
}

enum FeedbackSentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

// ===========================================
// DOMAIN 1: TENANT
// ===========================================

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @db.VarChar(255)
  slug      String       @unique @db.VarChar(100)
  domain    String?      @db.VarChar(255)
  settings  Json?        @default("{}")
  status    TenantStatus @default(ACTIVE)
  plan      TenantPlan   @default(FREE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  users               User[]
  customers            Customer[]
  customerTags         CustomerTag[]
  orders               Order[]
  orderItems           OrderItem[]
  events               Event[]
  customerMetrics      CustomerMetric[]
  customerMetricsHistory CustomerMetricHistory[]
  customerFeatures     CustomerFeature[]
  personas             Persona[]
  customerPersonas     CustomerPersona[]
  segments             Segment[]
  segmentCustomers     SegmentCustomer[]
  segmentVersions      SegmentVersion[]
  businessGoals        BusinessGoal[]
  decisions            Decision[]
  decisionOutcomes     DecisionOutcome[]
  campaigns            Campaign[]
  campaignVersions     CampaignVersion[]
  campaignMessages     CampaignMessage[]
  campaignAudiences    CampaignAudience[]
  communicationLogs    CommunicationLog[]
  deliveryReceipts     DeliveryReceipt[]
  campaignAnalytics    CampaignAnalytic[]
  revenueAttributions  RevenueAttribution[]
  auditLogs            AuditLog[]
  aiInteractions       AIInteraction[]
  learningExamples     LearningExample[]
  rateLimitRules       RateLimitRule[]
  apiUsageLogs         ApiUsageLog[]
  channelProviders     ChannelProvider[]
  deliveryEvents       DeliveryEvent[]
  // Phase 2A relations
  customerIdentities     CustomerIdentity[]
  customerAddresses      CustomerAddress[]
  customerDevices        CustomerDevice[]
  customerChannels       CustomerChannel[]
  customerPreferences    CustomerPreference[]
  customerConsents       CustomerConsent[]
  productCategories      ProductCategory[]
  products               Product[]
  productAttributes      ProductAttribute[]
  productAttributeValues ProductAttributeValue[]
  customerProductAffinities CustomerProductAffinity[]
  featureDefinitions     FeatureDefinition[]
  featureVersions        FeatureVersion[]
  featureComputationRuns FeatureComputationRun[]
  decisionTemplates      DecisionTemplate[]
  decisionRules          DecisionRule[]
  decisionExplanations   DecisionExplanation[]
  decisionExperiments    DecisionExperiment[]
  offers                 Offer[]
  offerTemplates         OfferTemplate[]
  offerAssignments       OfferAssignment[]
  offerPerformances      OfferPerformance[]
  workflows              Workflow[]
  workflowSteps          WorkflowStep[]
  workflowExecutions     WorkflowExecution[]
  workflowExecutionSteps WorkflowExecutionStep[]
  agentMemories          AgentMemory[]
  agentObservations      AgentObservation[]
  agentFeedbacks         AgentFeedback[]
  metricDefinitions      MetricDefinition[]
  metricSnapshots        MetricSnapshot[]
  dashboardWidgets       DashboardWidget[]
  // Phase 3.5 relations
  customerCategoryAffinities CustomerCategoryAffinity[]
  offerVersions          OfferVersion[]
  conversations          Conversation[]

  @@map("tenants")
}

// ===========================================
// DOMAIN 2: AUTH
// ===========================================

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  email        String     @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  firstName    String     @map("first_name") @db.VarChar(100)
  lastName     String     @map("last_name") @db.VarChar(100)
  role         UserRole   @default(VIEWER)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdSegments  Segment[]          @relation("SegmentCreator")
  segmentVersions  SegmentVersion[]   @relation("SegmentVersionChanger")
  createdGoals     BusinessGoal[]     @relation("GoalCreator")
  approvedDecisions Decision[]        @relation("DecisionApprover")
  decisionFeedback DecisionOutcome[]  @relation("OutcomeFeedbackBy")
  createdCampaigns Campaign[]         @relation("CampaignCreator")
  campaignVersions CampaignVersion[]  @relation("CampaignVersionChanger")
  auditLogs        AuditLog[]
  conversations    Conversation[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
  @@map("users")
}

// ===========================================
// DOMAIN 3: CUSTOMER (with normalized tags)
// ===========================================

model Customer {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  externalId        String?        @map("external_id") @db.VarChar(255)
  email             String?        @db.VarChar(255)
  phone             String?        @db.VarChar(50)
  firstName         String?        @map("first_name") @db.VarChar(100)
  lastName          String?        @map("last_name") @db.VarChar(100)
  gender            CustomerGender @default(UNKNOWN)
  dateOfBirth       DateTime?      @map("date_of_birth") @db.Date
  city              String?        @db.VarChar(100)
  state             String?        @db.VarChar(100)
  country           String?        @db.VarChar(10) // ISO 3166-1 alpha-2
  metadata          Json?          @default("{}")
  status            CustomerStatus @default(ACTIVE)
  acquisitionSource String?        @map("acquisition_source") @db.VarChar(100)
  acquisitionDate   DateTime?      @map("acquisition_date") @db.Timestamptz
  firstSeenAt       DateTime?      @map("first_seen_at") @db.Timestamptz
  lastSeenAt        DateTime?      @map("last_seen_at") @db.Timestamptz
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?      @map("deleted_at") @db.Timestamptz // Soft delete

  // Relations
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tagAssignments     CustomerTagAssignment[]
  orders             Order[]
  customerMetrics    CustomerMetric[]
  customerMetricsHistory CustomerMetricHistory[]
  customerFeatures   CustomerFeature[]
  customerPersonas   CustomerPersona[]
  segmentCustomers   SegmentCustomer[]
  campaignAudiences  CampaignAudience[]
  communicationLogs  CommunicationLog[]
  revenueAttributions RevenueAttribution[]
  // Phase 2A relations
  identities             CustomerIdentity[]
  addresses              CustomerAddress[]
  devices                CustomerDevice[]
  channels               CustomerChannel[]
  preferences            CustomerPreference?
  consents               CustomerConsent[]
  productAffinities      CustomerProductAffinity[]
  offerAssignments       OfferAssignment[]
  categoryAffinities     CustomerCategoryAffinity[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([status])
  @@index([city])
  @@index([country])
  @@index([acquisitionSource])
  @@map("customers")
}

// Normalized Tags
model CustomerTag {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(100)
  color     String?  @db.VarChar(7) // Hex color
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments CustomerTagAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("customer_tags")
}

model CustomerTagAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz

  // Relations
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
  @@index([tenantId])
  @@index([customerId])
  @@index([tagId])
  @@map("customer_tag_assignments")
}

// ===========================================
// DOMAIN 4: ORDERS
// ===========================================

model Order {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @map("tenant_id") @db.Uuid
  customerId     String      @map("customer_id") @db.Uuid
  externalId     String?     @map("external_id") @db.VarChar(255)
  orderNumber    String?     @map("order_number") @db.VarChar(100)
  status         OrderStatus @default(PENDING)
  totalAmount    Decimal     @map("total_amount") @db.Decimal(12, 2)
  currency       String      @default("INR") @db.VarChar(3) // ISO 4217
  discountAmount Decimal?    @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal?    @map("tax_amount") @db.Decimal(12, 2)
  channel        String?     @db.VarChar(50) // ONLINE, IN_STORE, APP
  metadata       Json?       @default("{}")
  orderedAt      DateTime    @map("ordered_at") @db.Timestamptz
  deliveredAt    DateTime?   @map("delivered_at") @db.Timestamptz
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer            Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items               OrderItem[]
  revenueAttributions RevenueAttribution[]

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, externalId])
  @@index([status])
  @@index([orderedAt])
  @@index([tenantId, orderedAt])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String  @map("product_id") @db.VarChar(255)
  productName String  @map("product_name") @db.VarChar(255)
  category    String? @db.VarChar(100)
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  metadata    Json?   @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId])
  @@index([productId])
  @@index([category])
  @@map("order_items")
}

// ===========================================
// DOMAIN 5: EVENTS (Immutable Event Store)
// ===========================================

model Event {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  entityType     String    @map("entity_type") @db.VarChar(50) // CUSTOMER, ORDER, CAMPAIGN, DECISION, MESSAGE
  entityId       String    @map("entity_id") @db.Uuid
  eventType      String    @map("event_type") @db.VarChar(100) // CUSTOMER_CREATED, ORDER_COMPLETED, etc.
  eventData      Json      @map("event_data")
  actorType      ActorType @map("actor_type") @default(SYSTEM)
  actorId        String?   @map("actor_id") @db.Uuid
  correlationId  String?   @map("correlation_id") @db.Uuid
  idempotencyKey String?   @unique @map("idempotency_key") @db.VarChar(255)
  version        Int       @default(1) // Event schema version
  occurredAt     DateTime  @map("occurred_at") @db.Timestamptz
  processedAt    DateTime? @map("processed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // NOTE: This table is APPEND-ONLY. No updates or deletes.
  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([eventType])
  @@index([tenantId, eventType])
  @@index([correlationId])
  @@index([occurredAt])
  @@index([tenantId, occurredAt])
  @@map("events")
}

// ===========================================
// DOMAIN 6: CUSTOMER INTELLIGENCE
// ===========================================

model CustomerMetric {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  customerId             String    @map("customer_id") @db.Uuid
  totalOrders            Int       @default(0) @map("total_orders")
  totalRevenue           Decimal   @default(0) @map("total_revenue") @db.Decimal(12, 2)
  avgOrderValue          Decimal   @default(0) @map("avg_order_value") @db.Decimal(12, 2)
  firstOrderAt           DateTime? @map("first_order_at") @db.Timestamptz
  lastOrderAt            DateTime? @map("last_order_at") @db.Timestamptz
  daysSinceLastOrder     Int?      @map("days_since_last_order")
  orderFrequencyDays     Decimal?  @map("order_frequency_days") @db.Decimal(8, 2)
  rfmRecencyScore        Int?      @map("rfm_recency_score") // 1-5
  rfmFrequencyScore      Int?      @map("rfm_frequency_score") // 1-5
  rfmMonetaryScore       Int?      @map("rfm_monetary_score") // 1-5
  rfmCombinedScore       Int?      @map("rfm_combined_score")
  engagementScore        Decimal?  @map("engagement_score") @db.Decimal(5, 2) // 0-100
  churnRiskScore         Decimal?  @map("churn_risk_score") @db.Decimal(5, 4) // 0.0000-1.0000
  lifetimeValue          Decimal?  @map("lifetime_value") @db.Decimal(12, 2)
  predictedNextOrderAt   DateTime? @map("predicted_next_order_at") @db.Timestamptz
  computedAt             DateTime  @map("computed_at") @db.Timestamptz
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId])
  @@index([rfmCombinedScore])
  @@index([churnRiskScore])
  @@index([engagementScore])
  @@index([computedAt])
  @@map("customer_metrics")
}

model CustomerMetricHistory {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  metricsSnapshot Json     @map("metrics_snapshot")
  computedAt      DateTime @map("computed_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([computedAt])
  @@map("customer_metrics_history")
}

// Extensible Feature Store (NEW)
model CustomerFeature {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  featureName    String   @map("feature_name") @db.VarChar(100)
  featureValue   Json     @map("feature_value") // Supports any value type
  featureVersion Int      @default(1) @map("feature_version")
  computedAt     DateTime @map("computed_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, featureName])
  @@index([tenantId, customerId])
  @@index([featureName])
  @@index([computedAt])
  @@map("customer_features")
}

// ===========================================
// DOMAIN 7: PERSONAS
// ===========================================

model Persona {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String        @db.VarChar(100)
  description String?       @db.Text
  criteria    Json?         // Rules defining the persona
  color       String?       @db.VarChar(7) // Hex color
  icon        String?       @db.VarChar(50)
  priority    Int           @default(0) // Evaluation order
  isSystem    Boolean       @default(false) @map("is_system")
  status      PersonaStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz // Soft delete

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerPersonas CustomerPersona[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@map("personas")
}

model CustomerPersona {
  id           String           @id @default(uuid()) @db.Uuid
  tenantId     String           @map("tenant_id") @db.Uuid
  customerId   String           @map("customer_id") @db.Uuid
  personaId    String           @map("persona_id") @db.Uuid
  confidence   Decimal          @default(0) @db.Decimal(5, 4) // 0-1
  assignedAt   DateTime         @default(now()) @map("assigned_at") @db.Timestamptz
  expiresAt    DateTime?        @map("expires_at") @db.Timestamptz
  assignedBy   PersonaAssignedBy @default(SYSTEM) @map("assigned_by")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  persona  Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId, personaId])
  @@index([tenantId, personaId])
  @@index([confidence])
  @@index([assignedAt])
  @@map("customer_personas")
}

// ===========================================
// DOMAIN 8: SEGMENTS
// ===========================================

model Segment {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  name           String        @db.VarChar(255)
  description    String?       @db.Text
  type           SegmentType   @default(DYNAMIC)
  rules          Json?         // Segment definition rules
  customerCount  Int           @default(0) @map("customer_count")
  status         SegmentStatus @default(ACTIVE)
  lastComputedAt DateTime?     @map("last_computed_at") @db.Timestamptz
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz // Soft delete

  // Relations
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
