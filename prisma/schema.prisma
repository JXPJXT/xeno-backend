// ===========================================
// DOMAIN 10: DECISIONS (AI Decision Engine)
// ===========================================

model Decision {
  id                      String         @id @default(uuid()) @db.Uuid
  tenantId                String         @map("tenant_id") @db.Uuid
  goalId                  String?        @map("goal_id") @db.Uuid
  goal                    String         @db.Text // Raw goal text input
  intent                  Json?          // Parsed intent from AI
  status                  DecisionStatus @default(PENDING)
  audience                Json?          // Who to target and why
  channelRecommendation   Json?          @map("channel_recommendation")
  offerRecommendation     Json?          @map("offer_recommendation")
  timingRecommendation    Json?          @map("timing_recommendation")
  contentRecommendation   Json?          @map("content_recommendation")
  reasoning               String?        @db.Text
  confidence              Decimal?       @db.Decimal(5, 4) // 0-1
  modelUsed               String?        @map("model_used") @db.VarChar(100)
  tokensUsed              Int?           @map("tokens_used")
  cost                    Decimal?       @db.Decimal(8, 4)
  approvedBy              String?        @map("approved_by") @db.Uuid
  approvedAt              DateTime?      @map("approved_at") @db.Timestamptz
  createdAt               DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessGoal     BusinessGoal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  approver         User?             @relation("DecisionApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  decisionOutcomes DecisionOutcome[]
  campaigns        Campaign[]
  // Phase 2A relations
  decisionRules        DecisionRule[]
  decisionExplanations DecisionExplanation[]

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([createdAt])
  @@map("decisions")
}

model DecisionOutcome {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  decisionId         String   @map("decision_id") @db.Uuid
  campaignId         String?  @map("campaign_id") @db.Uuid
  metrics            Json?    // Outcome metrics
  effectivenessScore Decimal? @map("effectiveness_score") @db.Decimal(5, 4)
  feedback           String?  @db.Text
  feedbackBy         String?  @map("feedback_by") @db.Uuid
  evaluatedAt        DateTime? @map("evaluated_at") @db.Timestamptz
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  decision     Decision  @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  feedbackUser User?     @relation("OutcomeFeedbackBy", fields: [feedbackBy], references: [id], onDelete: SetNull)

  @@index([tenantId, decisionId])
  @@index([tenantId, campaignId])
  @@map("decision_outcomes")
}

